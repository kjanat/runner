{
	"name": "runner-site",
	"version": "0.0.0",
	"private": true,
	"description": "static site for the runner CLI",
	"homepage": "https://runner.kjanat.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/runner.git",
		"directory": "site"
	},
	"type": "module",
	"scripts": {
		"prebuild": "bun run gen",
		"build": "vite build",
		"check": "bun run gen && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"deploy": "bun run build && wrangler deploy",
		"dev": "bun run gen && vite dev",
		"fmt": "bunx dprint fmt",
		"gen": "bun scripts/gen-site-data.ts",
		"preview": "vite preview",
		"test": "bun run gen && vitest run"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.13",
		"svelte": "^5.43.2",
		"svelte-check": "^4.4.1",
		"typescript": "^6",
		"vite": "^8.0.13",
		"vitest": "^4.1.6",
		"wrangler": "^4.93.0"
	}
}
