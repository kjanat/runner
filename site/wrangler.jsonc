{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "runner-site",
  "compatibility_date": "2026-05-05",
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "runner.kjanat.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  },
  "workers_dev": false
}
